document.getElementById('ctrl-gain').addEventListener('input', function() {
  gain = parseFloat(this.value);
  document.getElementById('val-gain').textContent = gain.toFixed(1);
});

const speedLabels = ['×0.5','×0.75','×1','×1.5','×2'];
const speedVals   = [0.5, 0.75, 1, 1.5, 2];
document.getElementById('ctrl-speed').addEventListener('input', function() {
  const i = parseInt(this.value) - 1;
  speedMul = speedVals[i];
  document.getElementById('val-speed').textContent = speedLabels[i];
});

document.getElementById('ctrl-trig').addEventListener('input', function() {
  trigLevel = parseInt(this.value);
  document.getElementById('val-trig').textContent = trigLevel;
});

// Mode pills
document.querySelectorAll('.pill').forEach(p => {
  p.addEventListener('click', () => {
    document.querySelectorAll('.pill').forEach(x => x.classList.remove('active'));
    p.classList.add('active');
    displayMode = p.dataset.mode;
    document.getElementById('disp-mode').textContent =
      displayMode === 'wave' ? 'WAVE' : displayMode === 'fft' ? 'FREQ' : 'BOTH';
  });
});

function toggleGrid() {
  showGrid = !showGrid;
  document.getElementById('btn-grid').classList.toggle('active', showGrid);
}
function toggleGlow() {
  showGlow = !showGlow;
  document.getElementById('btn-glow').classList.toggle('active', showGlow);
}
function toggleFreeze() {
  frozen = !frozen;
  document.getElementById('btn-freeze').classList.toggle('active', frozen);
  document.getElementById('btn-freeze').textContent = frozen ? '▶ RESUME' : '⏸ FREEZE';
}
function toggleInvert() {
  inverted = !inverted;
  document.getElementById('btn-invert').classList.toggle('active', inverted);
  document.getElementById('screen-outer').style.background = inverted ? '#f0fff0' : '#020902';
}
